<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sk.spse.uloha1.declarative.Controller">

    <children>

        <!-- Celsius -->
        <HBox alignment="CENTER_RIGHT" spacing="20">
            <padding>
                <Insets topRightBottomLeft="10"/>
            </padding>

            <Label text="Stupne Celsius:"/>
            <TextField fx:id="tfCelsius"
                       onKeyReleased="#onCelsiusKeyTyped"
                       style="-fx-padding: 10 20 10 20;"/>
            <Label text="°C"/>
        </HBox>

        <!-- Fahrenheit -->
        <HBox alignment="CENTER" spacing="20">
            <padding>
                <Insets topRightBottomLeft="10"/>
            </padding>

            <Label text="Stupne Fahrenheit:"/>
            <TextField fx:id="tfFahrenheit"
                       onKeyReleased="#onFahrenheitKeyTyped"
                       style="-fx-padding: 10 20 10 20;"/>
            <Label text="°F"/>
        </HBox>

    </children>
</VBox>